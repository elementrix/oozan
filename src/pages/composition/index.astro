---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import YouTubeFacade from '../../components/YouTubeFacade.astro';
import { withBase } from '../../lib/url';

const tracks = (await getCollection('compositions')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="작곡" description="Oozan이 작곡한 음원과 영상.">
	<section class="section container">
		<div class="page-head">
			<p class="eyebrow">Composition</p>
			<h1 class="display-1">작곡</h1>
			<p class="lede">'좌니뭐하니'라는 이름으로 만든 곡들입니다.</p>
		</div>

		<div class="track-list">
			{
				tracks.map((track, i) => (
					<div class="track" id={track.id}>
						{track.data.type === 'audio' && track.data.audio ? (
							<AudioPlayer
								title={track.data.title}
								subtitle={track.data.subtitle}
								src={withBase(track.data.audio)}
								index={i + 1}
							/>
						) : (
							track.data.cover && (
								<article class="track__video">
									<div class="track__video-media">
										<YouTubeFacade
											youtubeId={track.data.youtubeId}
											cover={track.data.cover}
											title={track.data.title}
										/>
									</div>
									<div class="track__video-body">
										<span class="track__index">{String(i + 1).padStart(2, '0')}</span>
										<h2 class="track__title">{track.data.title}</h2>
										{track.data.subtitle && <p class="track__subtitle">{track.data.subtitle}</p>}
									</div>
								</article>
							)
						)}
						{track.data.description && <p class="track__desc">{track.data.description}</p>}
					</div>
				))
			}
		</div>
	</section>
</BaseLayout>

<style>
	.page-head {
		max-width: 60ch;
	}

	.page-head .display-1 {
		margin-top: 0.75rem;
	}

	.page-head .lede {
		margin-top: 1.25rem;
	}

	.track-list {
		margin-top: clamp(3rem, 7vw, 5rem);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.track__desc {
		margin-top: 0.75rem;
		padding-left: clamp(1.25rem, 3vw, 2rem);
		color: var(--color-text-dim);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.track__video {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: start;
	}

	.track__index {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--color-accent);
	}

	.track__title {
		margin-top: 0.5rem;
		font-size: clamp(1.4rem, 2.6vw, 1.9rem);
		font-weight: 800;
		letter-spacing: -0.01em;
	}

	.track__subtitle {
		margin-top: 0.4rem;
		font-size: 0.85rem;
		color: var(--color-text-faint);
	}

	@media (max-width: 900px) {
		.track__video {
			grid-template-columns: 1fr;
		}
	}
</style>
