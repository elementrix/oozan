---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Bookshelf from '../components/Bookshelf.astro';
import { withBase } from '../lib/url';

import filmsCover from '../assets/films/premium-project.jpg';
import snapCover from '../assets/snap/lee-eunmin/01.jpg';
import compositionCover from '../assets/composition/geuriun-norae.jpg';

const [films, research, compositions, people] = await Promise.all([
	getCollection('films'),
	getCollection('research'),
	getCollection('compositions'),
	getCollection('people'),
]);

const panels = [
	{
		key: '01',
		title: '필모',
		titleEn: 'FILMS',
		meta: `${films.length} WORKS`,
		description: '기획하고 촬영·편집한 영상 작업들.',
		href: withBase('/films/'),
		color: 'var(--color-spine-1)',
		image: filmsCover,
	},
	{
		key: '02',
		title: '스냅',
		titleEn: 'SNAP',
		meta: `${people.length} PEOPLE`,
		description: '일곱 명의 인물을 담은 스냅 기록.',
		href: withBase('/snap/'),
		color: 'var(--color-spine-2)',
		image: snapCover,
	},
	{
		key: '03',
		title: '연구',
		titleEn: 'RESEARCH',
		meta: `${research.length} PAPER`,
		description: '아스펙트 기반 감정 분석을 중심으로 진행한 연구.',
		href: withBase('/research/'),
		color: 'var(--color-spine-3)',
	},
	{
		key: '04',
		title: '작곡',
		titleEn: 'COMPOSITION',
		meta: `${compositions.length} TRACKS`,
		description: "'좌니뭐하니'라는 이름으로 만든 곡들.",
		href: withBase('/composition/'),
		color: 'var(--color-spine-4)',
		image: compositionCover,
	},
];
---

<BaseLayout title="Oozan — Portfolio" hideFooter>
	<Bookshelf panels={panels} />
</BaseLayout>
