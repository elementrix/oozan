---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Bookshelf from '../components/Bookshelf.astro';
import GlassButton from '../components/GlassButton.astro';
import { withBase } from '../lib/url';

import filmsCover from '../assets/films/premium-project.jpg';
import snapCover from '../assets/snap/lee-eunmin/01.jpg';
import compositionCover from '../assets/composition/geuriun-norae.jpg';

const [films, research, compositions, people] = await Promise.all([
	getCollection('films'),
	getCollection('research'),
	getCollection('compositions'),
	getCollection('people'),
]);

const email = 'sgh04069@gmail.com';

const panels = [
	{
		key: '01',
		title: '필모',
		titleEn: 'FILMS',
		meta: `${films.length} WORKS`,
		description: '기획하고 촬영·편집한 영상 작업들.',
		href: withBase('/films/'),
		color: '#6e2d16',
		image: filmsCover,
	},
	{
		key: '02',
		title: '스냅',
		titleEn: 'SNAP',
		meta: `${people.length} PEOPLE`,
		description: '일곱 명의 인물을 담은 스냅 기록.',
		href: withBase('/snap/'),
		color: '#39402f',
		image: snapCover,
	},
	{
		key: '03',
		title: '연구',
		titleEn: 'RESEARCH',
		meta: `${research.length} PAPER`,
		description: '아스펙트 기반 감정 분석을 중심으로 진행한 연구.',
		href: withBase('/research/'),
		color: '#1b2340',
	},
	{
		key: '04',
		title: '작곡',
		titleEn: 'COMPOSITION',
		meta: `${compositions.length} TRACKS`,
		description: "'좌니뭐하니'라는 이름으로 만든 곡들.",
		href: withBase('/composition/'),
		color: '#5b3a1a',
		image: compositionCover,
	},
];
---

<BaseLayout title="Oozan — Portfolio">
	<section>
		<Bookshelf panels={panels} />
	</section>

	<section class="section container about">
		<div class="about__inner">
			<p class="eyebrow">About</p>
			<p class="about__text">
				한국항공대학교에서 컴퓨터공학을 공부하며 감정 분석 연구를 하는 동시에, 카메라와 음악으로도 기록을 남깁니다.
				이 사이트는 그 결과물들을 모아둔 아카이브입니다.
			</p>
			<GlassButton href={`mailto:${email}`}>연락하기 — {email}</GlassButton>
		</div>
	</section>
</BaseLayout>

<style>
	.about__inner {
		max-width: 62ch;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.about__text {
		font-size: clamp(1.1rem, 2vw, 1.4rem);
		line-height: 1.7;
		color: var(--color-text);
	}

	.about__inner :global(.glass-btn) {
		align-self: flex-start;
	}
</style>
