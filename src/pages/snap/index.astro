---
import { getCollection } from 'astro:content';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PersonSection from '../../components/PersonSection.astro';

const people = (await getCollection('people')).sort((a, b) => a.data.order - b.data.order);

const galleryModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/snap/*/*.jpg', {
	eager: true,
});

const galleriesBySlug = new Map<string, ImageMetadata[]>();
for (const [path, mod] of Object.entries(galleryModules)) {
	const match = path.match(/\/snap\/([^/]+)\//);
	if (!match) continue;
	const slug = match[1];
	const list = galleriesBySlug.get(slug) ?? [];
	list.push(mod.default);
	galleriesBySlug.set(slug, list);
}
for (const list of galleriesBySlug.values()) {
	list.sort((a, b) => a.src.localeCompare(b.src));
}
---

<BaseLayout title="스냅" description="Oozan이 촬영한 인물 스냅 아카이브.">
	<section class="section container">
		<div class="page-head">
			<p class="eyebrow">Snap</p>
			<h1 class="display-1">스냅</h1>
			<p class="lede">일곱 명의 인물을 담은 스냅 기록입니다.</p>
		</div>

		<nav class="snap-jump" aria-label="인물 바로가기">
			{
				people.map((person) => (
					<a href={`#${person.data.slug}`}>{person.data.name}</a>
				))
			}
		</nav>

		<div class="snap-list">
			{
				people.map((person, i) => (
					<PersonSection
						id={person.data.slug}
						name={person.data.name}
						nameEn={person.data.nameEn}
						index={i + 1}
						bio={person.data.bio}
						images={galleriesBySlug.get(person.data.slug) ?? []}
					/>
				))
			}
		</div>
	</section>
</BaseLayout>

<style>
	.page-head {
		max-width: 60ch;
	}

	.page-head .display-1 {
		margin-top: 0.75rem;
	}

	.page-head .lede {
		margin-top: 1.25rem;
	}

	.snap-jump {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		margin-top: clamp(2rem, 5vw, 3rem);
		padding-bottom: clamp(2rem, 5vw, 3rem);
	}

	.snap-jump a {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-text-dim);
		padding: 0.5rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	.snap-jump a:hover {
		color: var(--color-text);
		border-color: var(--color-border-strong);
	}
</style>
