---
interface Props {
	href?: string;
	variant?: 'pill' | 'play';
	target?: string;
	rel?: string;
	class?: string;
}

const { href, variant = 'pill', target, rel, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
	class:list={['glass-btn', `glass-btn--${variant}`, className]}
	href={href}
	target={target}
	rel={rel}
>
	{
		variant === 'play' ? (
			<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
				<path d="M8 5.14v13.72a1 1 0 0 0 1.5.87l11-6.86a1 1 0 0 0 0-1.72l-11-6.86A1 1 0 0 0 8 5.14Z" />
			</svg>
		) : (
			<slot />
		)
	}
</Tag>

<style>
	.glass-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border: 1px solid var(--color-glass-border);
		background: var(--color-glass-bg);
		backdrop-filter: blur(18px) saturate(160%);
		-webkit-backdrop-filter: blur(18px) saturate(160%);
		color: var(--color-text);
		font-family: inherit;
		font-weight: 600;
		letter-spacing: 0.01em;
		transition:
			background 0.25s ease,
			border-color 0.25s ease,
			transform 0.25s ease;
	}

	.glass-btn--pill {
		padding: 0.85rem 1.6rem;
		font-size: 0.9rem;
	}

	.glass-btn--pill:hover {
		background: var(--color-text);
		border-color: var(--color-text);
		color: var(--color-bg);
	}

	.glass-btn--play {
		width: 4.5rem;
		height: 4.5rem;
		flex-shrink: 0;
		background: rgba(20, 20, 22, 0.45);
		border-color: rgba(255, 255, 255, 0.35);
		color: #fff;
	}

	.glass-btn--play svg {
		margin-left: 2px;
	}

	.glass-btn--play:hover {
		background: rgba(255, 255, 255, 0.16);
		border-color: #fff;
		transform: scale(1.08);
	}
</style>
