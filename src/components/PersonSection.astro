---
import type { ImageMetadata } from 'astro';
import ImageGrid from './ImageGrid.astro';

interface Props {
	id: string;
	name: string;
	nameEn?: string;
	index: number;
	bio?: string;
	images: ImageMetadata[];
}

const { id, name, nameEn, index, bio, images } = Astro.props;
---

<section class="person" id={id}>
	<div class="person__head">
		<span class="person__index">{String(index).padStart(2, '0')}</span>
		<div>
			<h2 class="person__name">{name}</h2>
			{nameEn && <p class="person__name-en">{nameEn}</p>}
			{bio && <p class="person__bio">{bio}</p>}
		</div>
	</div>
	<ImageGrid images={images} alt={name} />
</section>

<style>
	.person {
		padding-block: clamp(3rem, 8vw, 6rem);
		border-top: 1px solid var(--color-border);
	}

	.person__head {
		display: flex;
		align-items: flex-start;
		gap: clamp(1rem, 3vw, 2rem);
		margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
	}

	.person__index {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--color-accent);
		letter-spacing: 0.04em;
		padding-top: 0.4rem;
	}

	.person__name {
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	.person__name-en {
		margin-top: 0.3rem;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-faint);
	}

	.person__bio {
		margin-top: 0.75rem;
		max-width: 56ch;
		color: var(--color-text-dim);
		line-height: 1.6;
	}
</style>
