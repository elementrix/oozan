---
interface Props {
	class?: string;
	crossLines?: boolean;
}

const { class: className = '', crossLines = true } = Astro.props;
---

<div class:list={['grid-frame', className]}>
	<slot />
	<div class="grid-frame__deco" aria-hidden="true">
		<svg class="grid-frame__corner grid-frame__corner--tl" viewBox="0 0 32 32">
			<path d="M2 14V6a4 4 0 0 1 4-4h8" fill="none" stroke-width="2" />
		</svg>
		<svg class="grid-frame__corner grid-frame__corner--tr" viewBox="0 0 32 32">
			<path d="M18 2h8a4 4 0 0 1 4 4v8" fill="none" stroke-width="2" />
		</svg>
		<svg class="grid-frame__corner grid-frame__corner--bl" viewBox="0 0 32 32">
			<path d="M2 18v8a4 4 0 0 0 4 4h8" fill="none" stroke-width="2" />
		</svg>
		<svg class="grid-frame__corner grid-frame__corner--br" viewBox="0 0 32 32">
			<path d="M30 18v8a4 4 0 0 1-4 4h-8" fill="none" stroke-width="2" />
		</svg>
		{
			crossLines && (
				<>
					<span class="grid-frame__line grid-frame__line--v" />
					<span class="grid-frame__line grid-frame__line--h" />
				</>
			)
		}
	</div>
</div>

<style>
	.grid-frame {
		position: relative;
		overflow: hidden;
	}

	.grid-frame__deco {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.grid-frame__corner {
		position: absolute;
		width: clamp(28px, 4vw, 44px);
		height: clamp(28px, 4vw, 44px);
		stroke: rgba(245, 243, 239, 0.75);
	}

	.grid-frame__corner--tl {
		top: clamp(0.75rem, 2vw, 1.75rem);
		left: clamp(0.75rem, 2vw, 1.75rem);
	}
	.grid-frame__corner--tr {
		top: clamp(0.75rem, 2vw, 1.75rem);
		right: clamp(0.75rem, 2vw, 1.75rem);
	}
	.grid-frame__corner--bl {
		bottom: clamp(0.75rem, 2vw, 1.75rem);
		left: clamp(0.75rem, 2vw, 1.75rem);
	}
	.grid-frame__corner--br {
		bottom: clamp(0.75rem, 2vw, 1.75rem);
		right: clamp(0.75rem, 2vw, 1.75rem);
	}

	.grid-frame__line {
		position: absolute;
		background: rgba(245, 243, 239, 0.18);
	}

	.grid-frame__line--v {
		top: 0;
		bottom: 0;
		left: 38%;
		width: 1px;
	}

	.grid-frame__line--h {
		left: 0;
		right: 0;
		top: 64%;
		height: 1px;
	}
</style>
