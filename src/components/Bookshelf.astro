---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import VideoChapter from './shelf/VideoChapter.astro';
import PersonChapter from './shelf/PersonChapter.astro';
import ResearchChapter from './shelf/ResearchChapter.astro';
import AudioChapter from './shelf/AudioChapter.astro';
import AboutChapter from './shelf/AboutChapter.astro';

export type Chapter =
	| { type: 'film'; title: string; description?: string; role?: string; youtubeId?: string; cover: ImageMetadata }
	| { type: 'person'; name: string; images: ImageMetadata[] }
	| {
			type: 'research';
			title: string;
			authors: string;
			venue: string;
			date: string;
			abstract: string;
			pdf: string;
			doi?: string;
	  }
	| { type: 'audio'; title: string; subtitle?: string; description?: string; src: string; cover?: ImageMetadata }
	| { type: 'video-track'; title: string; description?: string; role?: string; youtubeId?: string; cover: ImageMetadata }
	| { type: 'about'; name: string; role: string; email: string; phone: string; instagram: string };

interface Panel {
	key: string;
	title: string;
	titleEn: string;
	meta: string;
	color: string;
	image?: ImageMetadata;
	chapters: Chapter[];
}

interface Props {
	panels: Panel[];
}

const { panels } = Astro.props;
---

<div class="shelf-wrap">
	<div class="shelf" data-shelf>
		{
			panels.map((p, i) => {
				// snap's photo carousel already uses left/right swipes for photo-to-photo
				// navigation inside a chapter, so it keeps vertical chapter-to-chapter
				// paging even on mobile — every other panel switches to horizontal
				// chapter paging on small screens where a second, nested swipe axis
				// isn't in play
				const chapterAxis = p.chapters.some((ch) => ch.type === 'person') ? 'vertical' : 'responsive';
				return (
				<div
					class="shelf__panel"
					data-panel
					data-chapter-axis={chapterAxis}
					tabindex="0"
					role="button"
					aria-expanded={i === 0 ? 'true' : 'false'}
					aria-label={`${p.title} 열기`}
					style={`--panel-color:${p.color}`}
				>
					<div class="shelf__cover">
						{p.image ? (
							<Image
								src={p.image}
								alt={p.title}
								class="shelf__cover-img"
								widths={[480, 900, 1400]}
								sizes="(max-width: 900px) 100vw, 60vw"
								loading={i === 0 ? 'eager' : 'lazy'}
							/>
						) : (
							<div class="shelf__cover-solid" aria-hidden="true" />
						)}
						<div class="shelf__scrim" aria-hidden="true" />
					</div>

					<span class="shelf__spine-label">
						{p.key} — {p.titleEn}
					</span>

					<div class="shelf__chapters">
						{p.chapters.map((ch, ci) => {
							const index = ci + 1;
							const chTotal = p.chapters.length;
							if (ch.type === 'film' || ch.type === 'video-track') {
								return (
									<VideoChapter
										title={ch.title}
										description={ch.description}
										role={ch.role}
										youtubeId={ch.youtubeId}
										cover={ch.cover}
										index={index}
										total={chTotal}
									/>
								);
							}
							if (ch.type === 'person') {
								return <PersonChapter name={ch.name} images={ch.images} index={index} total={chTotal} />;
							}
							if (ch.type === 'research') {
								return (
									<ResearchChapter
										title={ch.title}
										authors={ch.authors}
										venue={ch.venue}
										date={ch.date}
										abstract={ch.abstract}
										pdf={ch.pdf}
										doi={ch.doi}
										index={index}
										total={chTotal}
									/>
								);
							}
							if (ch.type === 'about') {
								return (
									<AboutChapter
										name={ch.name}
										role={ch.role}
										email={ch.email}
										phone={ch.phone}
										instagram={ch.instagram}
										index={index}
										total={chTotal}
									/>
								);
							}
							return (
								<AudioChapter
									title={ch.title}
									subtitle={ch.subtitle}
									description={ch.description}
									src={ch.src}
									cover={ch.cover}
									index={index}
									total={chTotal}
								/>
							);
						})}
					</div>

					{p.chapters.length > 1 && (
						<div class="shelf__dots" data-shelf-dots aria-hidden="true">
							{p.chapters.map((_, ci) => (
								<button
									class="shelf__dot"
									type="button"
									data-dot-index={ci}
									aria-current={ci === 0 ? 'true' : 'false'}
									aria-label={`챕터 ${ci + 1}`}
								/>
							))}
						</div>
					)}
				</div>
				);
			})
		}
	</div>
</div>

<style>
	.shelf-wrap {
		display: flex;
		flex-direction: column;
		height: calc(100vh - var(--header-h) - 1px);
	}

	.shelf {
		--spine-w: 84px;
		display: flex;
		width: 100%;
		flex: 1 1 auto;
		min-height: 0;
		background: #000;
		gap: 2px;
	}

	.shelf__panel {
		position: relative;
		flex: 0 0 auto;
		width: var(--spine-w);
		overflow: hidden;
		cursor: pointer;
		background: var(--panel-color);
		border: 0;
		padding: 0;
		text-align: left;
		/* width/height are set in px by JS so this always transitions px -> px
		   (mixed units like 84px -> 0% can't interpolate smoothly and just jump) */
		transition:
			width 0.75s cubic-bezier(0.42, 0, 1, 1),
			height 0.75s cubic-bezier(0.42, 0, 1, 1);
	}

	.shelf__panel[aria-expanded='true'] {
		cursor: default;
	}

	.shelf__cover {
		position: absolute;
		inset: 0;
		transition: filter 0.3s ease;
	}

	.shelf__panel:not([aria-expanded='true']):hover .shelf__cover {
		filter: brightness(1.25);
	}

	.shelf__cover :global(.shelf__cover-img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.shelf__cover-solid {
		position: absolute;
		inset: 0;
		background: var(--panel-color);
	}

	.shelf__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(0deg, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.15) 42%, rgba(0, 0, 0, 0.3) 100%);
	}

	.shelf__spine-label {
		position: absolute;
		top: 2rem;
		left: 0;
		right: 0;
		display: flex;
		justify-content: center;
		writing-mode: vertical-rl;
		text-orientation: mixed;
		font-weight: 800;
		font-size: 1rem;
		letter-spacing: 0.12em;
		color: #fff;
		white-space: nowrap;
		transition: opacity 0.25s ease;
	}

	.shelf__panel[aria-expanded='true'] .shelf__spine-label {
		opacity: 0;
		pointer-events: none;
	}

	.shelf__chapters {
		position: absolute;
		inset: 0;
		overflow-y: hidden;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.shelf__panel[aria-expanded='true'] .shelf__chapters {
		opacity: 1;
		transition-delay: 0.5s;
	}

	.shelf__panel:not([aria-expanded='true']) .shelf__chapters {
		pointer-events: none;
	}

	.shelf__dots {
		position: absolute;
		top: 50%;
		right: clamp(1rem, 2vw, 2.25rem);
		transform: translateY(-50%);
		z-index: 5;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 0.5rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.14);
		border: 1px solid rgba(255, 255, 255, 0.28);
		backdrop-filter: blur(16px) saturate(180%);
		-webkit-backdrop-filter: blur(16px) saturate(180%);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.shelf__panel[aria-expanded='true'] .shelf__dots {
		opacity: 1;
		transition-delay: 0.5s;
	}

	.shelf__panel:not([aria-expanded='true']) .shelf__dots {
		pointer-events: none;
	}

	.shelf__dot {
		width: 4px;
		height: 14px;
		padding: 0;
		border: 0;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.5);
		cursor: pointer;
		transition:
			height 0.25s ease,
			background 0.25s ease;
	}

	.shelf__dot:hover {
		background: rgba(255, 255, 255, 0.7);
	}

	.shelf__dot[aria-current='true'] {
		height: 26px;
		background: #fff;
	}

	@media (max-width: 720px) {
		/* on mobile, panels stack like books lying flat at the bottom instead of
		   standing as spines along the side — the active panel gets the full
		   width so the horizontal view isn't squeezed by 3 side strips */
		.shelf {
			--spine-h: 56px;
			flex-direction: column;
		}

		.shelf__panel {
			width: 100%;
			/* height set by JS, mirroring how width works on desktop */
		}

		.shelf__spine-label {
			top: 50%;
			left: 1.25rem;
			right: 1.25rem;
			justify-content: flex-start;
			writing-mode: horizontal-tb;
			text-orientation: initial;
			transform: translateY(-50%);
			font-size: 0.85rem;
		}

		/* panels without a nested horizontal swipe (everything but snap's photo
		   carousel) page chapters left/right on mobile instead of up/down */
		.shelf__panel[data-chapter-axis='responsive'] .shelf__chapters {
			display: flex;
			flex-direction: row;
			overflow-x: hidden;
		}

		.shelf__panel[data-chapter-axis='responsive'] .shelf__chapters > :global(.chapter) {
			flex: 0 0 100%;
			height: 100%;
		}

		.shelf__panel[data-chapter-axis='responsive'] .shelf__dots {
			top: clamp(1rem, 3vw, 1.5rem);
			left: 50%;
			right: auto;
			bottom: auto;
			transform: translateX(-50%);
			flex-direction: row;
		}

		.shelf__panel[data-chapter-axis='responsive'] .shelf__dot {
			width: 14px;
			height: 4px;
		}

		.shelf__panel[data-chapter-axis='responsive'] .shelf__dot[aria-current='true'] {
			width: 26px;
			height: 4px;
		}
	}
</style>

<script>
	// loaded once and reused for every chapter — gives us a real player object
	// (getCurrentTime/getDuration/seekTo/mute) instead of guessing at iframe
	// readiness through raw postMessage calls
	let ytApiPromise: Promise<void> | null = null;
	function loadYouTubeApi(): Promise<void> {
		if (ytApiPromise) return ytApiPromise;
		ytApiPromise = new Promise((resolve) => {
			const w = window as any;
			if (w.YT?.Player) {
				resolve();
				return;
			}
			const prev = w.onYouTubeIframeAPIReady;
			w.onYouTubeIframeAPIReady = () => {
				prev?.();
				resolve();
			};
			const script = document.createElement('script');
			script.src = 'https://www.youtube.com/iframe_api';
			document.head.appendChild(script);
		});
		return ytApiPromise;
	}

	const players = new Map<HTMLElement, any>();
	const progressIntervals = new Map<HTMLElement, number>();

	function formatTime(seconds: number): string {
		const total = Math.max(0, Math.floor(seconds));
		const m = Math.floor(total / 60);
		const s = total % 60;
		return `${m}:${String(s).padStart(2, '0')}`;
	}

	function startProgressPolling(el: HTMLElement, player: any) {
		const fill = el.querySelector<HTMLElement>('[data-progress-fill]');
		const slider = el.querySelector<HTMLInputElement>('[data-volume-slider]');
		if (slider) slider.value = String(player.getVolume?.() ?? 100);
		const interval = window.setInterval(() => {
			if (el.dataset.playing !== 'true' || !fill) return;
			const duration = player.getDuration?.();
			const current = player.getCurrentTime?.();
			if (duration) fill.style.width = `${Math.min(100, (current / duration) * 100)}%`;
		}, 250);
		progressIntervals.set(el, interval);
	}

	async function playChapterVideo(el: HTMLElement) {
		if (el.dataset.playing === 'true') return;
		const youtubeId = el.dataset.youtube;
		if (!youtubeId) return;
		const media = el.querySelector('.chapter__media');
		if (!media) return;
		el.dataset.playing = 'true';
		await loadYouTubeApi();
		if (el.dataset.playing !== 'true') return; // stopped while the API was loading

		const mount = document.createElement('div');
		media.appendChild(mount);
		const player = new (window as any).YT.Player(mount, {
			videoId: youtubeId,
			host: 'https://www.youtube-nocookie.com',
			playerVars: { autoplay: 1, mute: 1, controls: 0, loop: 1, playlist: youtubeId, rel: 0, modestbranding: 1 },
			events: { onReady: () => startProgressPolling(el, player) },
		});
		player.getIframe()?.classList.add('chapter__iframe');
		players.set(el, player);
	}

	function stopChapterVideo(el: HTMLElement) {
		if (el.dataset.playing !== 'true') return;
		el.dataset.playing = 'false';
		const player = players.get(el);
		players.delete(el);
		const interval = progressIntervals.get(el);
		if (interval !== undefined) {
			clearInterval(interval);
			progressIntervals.delete(el);
		}
		player?.destroy?.();
		const fill = el.querySelector<HTMLElement>('[data-progress-fill]');
		if (fill) fill.style.width = '0%';
		const muteBtn = el.querySelector<HTMLButtonElement>('[data-mute-toggle]');
		if (muteBtn) {
			muteBtn.dataset.muted = 'true';
			muteBtn.setAttribute('aria-label', '음소거 해제');
		}
		const slider = el.querySelector<HTMLInputElement>('[data-volume-slider]');
		if (slider) slider.value = '100';
	}

	function initVolumeControl(chapter: HTMLElement) {
		const btn = chapter.querySelector<HTMLButtonElement>('[data-mute-toggle]');
		const slider = chapter.querySelector<HTMLInputElement>('[data-volume-slider]');
		if (!btn || !slider) return;

		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const player = players.get(chapter);
			if (!player) return;
			const wasMuted = btn.dataset.muted !== 'false';
			if (wasMuted) {
				player.unMute();
				if (player.getVolume() === 0) player.setVolume(100);
				slider.value = String(player.getVolume());
			} else {
				player.mute();
			}
			btn.dataset.muted = String(!wasMuted);
			btn.setAttribute('aria-label', wasMuted ? '음소거' : '음소거 해제');
		});

		slider.addEventListener('click', (e) => e.stopPropagation());
		slider.addEventListener('input', () => {
			const player = players.get(chapter);
			if (!player) return;
			const vol = Number(slider.value);
			player.setVolume(vol);
			const muted = vol === 0;
			if (muted) player.mute();
			else player.unMute();
			btn.dataset.muted = String(muted);
			btn.setAttribute('aria-label', muted ? '음소거 해제' : '음소거');
		});
	}

	function initProgressSeek(chapter: HTMLElement) {
		const bar = chapter.querySelector<HTMLElement>('[data-progress]');
		const timeLabel = chapter.querySelector<HTMLElement>('[data-progress-time]');
		if (!bar) return;

		function fracFromEvent(e: MouseEvent) {
			const rect = bar!.getBoundingClientRect();
			return Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
		}

		bar.addEventListener('mousemove', (e) => {
			const player = players.get(chapter);
			const duration = player?.getDuration?.();
			if (!duration || !timeLabel) return;
			const frac = fracFromEvent(e);
			timeLabel.textContent = formatTime(frac * duration);
			timeLabel.style.left = `${frac * 100}%`;
		});

		bar.addEventListener('click', (e) => {
			e.stopPropagation();
			const player = players.get(chapter);
			const duration = player?.getDuration?.();
			if (!player || !duration) return;
			player.seekTo(fracFromEvent(e) * duration, true);
		});
	}

	function initFullscreenToggle(chapter: HTMLElement) {
		const btn = chapter.querySelector<HTMLButtonElement>('[data-fullscreen-toggle]');
		if (!btn) return;
		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			if (document.fullscreenElement === chapter) document.exitFullscreen();
			else chapter.requestFullscreen();
		});
		document.addEventListener('fullscreenchange', () => {
			const isFs = document.fullscreenElement === chapter;
			btn.dataset.fullscreen = String(isFs);
			btn.setAttribute('aria-label', isFs ? '전체화면 종료' : '전체화면');
		});
	}

	document.querySelectorAll<HTMLElement>('[data-video-chapter]').forEach((chapter) => {
		initVolumeControl(chapter);
		initProgressSeek(chapter);
		initFullscreenToggle(chapter);
	});

	// drives paging within one panel's chapter stack: wheel/touch nudge -> snap to next/prev chapter
	function initChapterPaging(panel: HTMLElement) {
		const chaptersEl = panel.querySelector<HTMLElement>('.shelf__chapters');
		if (!chaptersEl) return null;
		// filter out non-chapter siblings (e.g. Astro can inject a deduped <script> tag inline here)
		const chapters = Array.from(chaptersEl.children).filter((el) =>
			el.classList.contains('chapter'),
		) as HTMLElement[];
		const dots = Array.from(panel.querySelectorAll<HTMLButtonElement>('.shelf__dot'));
		// panels without a nested horizontal swipe (see the 'responsive' attribute
		// set in the template) page left/right on mobile instead of up/down
		const isResponsiveAxis = panel.dataset.chapterAxis === 'responsive';
		let current = 0;
		let cooling = false;

		function isMobileAxis() {
			return isResponsiveAxis && window.matchMedia('(max-width: 720px)').matches;
		}

		function updateDots() {
			dots.forEach((d, i) => d.setAttribute('aria-current', String(i === current)));
		}

		function playCurrentIfVideo() {
			const el = chapters[current];
			if (el?.hasAttribute('data-video-chapter')) playChapterVideo(el);
		}

		function goTo(index: number) {
			index = Math.max(0, Math.min(chapters.length - 1, index));
			if (index === current) return;
			const leaving = chapters[current];
			if (leaving?.hasAttribute('data-video-chapter')) stopChapterVideo(leaving);
			// audio is a plain same-origin <audio> element, so pausing it directly
			// is enough — its own script reacts to the native 'pause' event to
			// keep its play/pause icon and progress bar in sync
			leaving?.querySelector('audio')?.pause();
			current = index;
			const target = chapters[current];
			if (isMobileAxis()) {
				chaptersEl!.scrollTo({ left: target.offsetLeft, behavior: 'smooth' });
			} else {
				chaptersEl!.scrollTo({ top: target.offsetTop, behavior: 'smooth' });
			}
			updateDots();
			playCurrentIfVideo();
		}

		// audio chapters dispatch this for their own prev/next-track buttons,
		// reusing the same panel-level paging the wheel/dots already drive
		chaptersEl.addEventListener('chapter-step', ((e: CustomEvent<{ dir: number }>) => {
			goTo(current + e.detail.dir);
		}) as EventListener);

		chaptersEl.addEventListener(
			'wheel',
			(e) => {
				if (panel.getAttribute('aria-expanded') !== 'true') return;
				const delta = isMobileAxis() ? e.deltaX : e.deltaY;
				if (Math.abs(delta) < 4) return;
				e.preventDefault();
				if (cooling) return;
				cooling = true;
				goTo(current + (delta > 0 ? 1 : -1));
				setTimeout(() => (cooling = false), 650);
			},
			{ passive: false },
		);

		let touchStartX: number | null = null;
		let touchStartY: number | null = null;
		chaptersEl.addEventListener(
			'touchstart',
			(e) => {
				touchStartX = e.touches[0]?.clientX ?? null;
				touchStartY = e.touches[0]?.clientY ?? null;
			},
			{ passive: true },
		);
		chaptersEl.addEventListener(
			'touchend',
			(e) => {
				if (touchStartY === null || cooling) return;
				const mobile = isMobileAxis();
				const delta = mobile
					? (touchStartX ?? 0) - (e.changedTouches[0]?.clientX ?? touchStartX ?? 0)
					: touchStartY - (e.changedTouches[0]?.clientY ?? touchStartY);
				touchStartX = null;
				touchStartY = null;
				if (Math.abs(delta) < 28) return;
				cooling = true;
				goTo(current + (delta > 0 ? 1 : -1));
				setTimeout(() => (cooling = false), 650);
			},
			{ passive: true },
		);

		dots.forEach((dot, i) => {
			dot.addEventListener('click', (e) => {
				e.stopPropagation();
				goTo(i);
			});
		});

		return {
			reset() {
				const playing = chapters[current];
				if (playing?.hasAttribute('data-video-chapter')) stopChapterVideo(playing);
				playing?.querySelector('audio')?.pause();
				current = 0;
				chaptersEl!.scrollTop = 0;
				chaptersEl!.scrollLeft = 0;
				updateDots();
			},
			playFirst: playCurrentIfVideo,
		};
	}

	function initShelf(shelf: HTMLElement) {
		const panels = Array.from(shelf.querySelectorAll<HTMLElement>('[data-panel]'));
		let active = panels.findIndex((p) => p.getAttribute('aria-expanded') === 'true');
		if (active < 0) active = 0;

		const pagers = panels.map((panel) => initChapterPaging(panel));

		// widths (or, on mobile, heights) are set explicitly in px (not via
		// flex-grow/flex-basis %) so the CSS transition always animates px -> px,
		// which is what actually interpolates smoothly — mixed units (e.g.
		// 84px -> 0%) just jump.
		function layout(animate: boolean) {
			const mobile = window.matchMedia('(max-width: 720px)').matches;
			const gap = 2;
			if (mobile) {
				const spineH = parseFloat(getComputedStyle(shelf).getPropertyValue('--spine-h')) || 56;
				const collapsedTotal = (panels.length - 1) * spineH + (panels.length - 1) * gap;
				const activeHeight = shelf.clientHeight - collapsedTotal;
				panels.forEach((p, i) => {
					if (!animate) p.style.transition = 'none';
					p.style.width = '';
					p.style.height = `${i === active ? activeHeight : spineH}px`;
				});
			} else {
				const spineW = parseFloat(getComputedStyle(shelf).getPropertyValue('--spine-w')) || 84;
				const collapsedTotal = (panels.length - 1) * spineW + (panels.length - 1) * gap;
				const activeWidth = shelf.clientWidth - collapsedTotal;
				panels.forEach((p, i) => {
					if (!animate) p.style.transition = 'none';
					p.style.height = '';
					p.style.width = `${i === active ? activeWidth : spineW}px`;
				});
			}
			if (!animate) {
				void shelf.offsetHeight;
				panels.forEach((p) => {
					p.style.transition = '';
				});
			}
		}

		function render() {
			panels.forEach((p, i) => p.setAttribute('aria-expanded', String(i === active)));
			layout(true);
		}

		function activate(i: number) {
			const prevIndex = active;
			active = (i + panels.length) % panels.length;
			render();
			if (prevIndex !== active) pagers[prevIndex]?.reset();
			requestAnimationFrame(() => pagers[active]?.playFirst());
		}

		panels.forEach((p, i) => {
			p.addEventListener('click', (e) => {
				if (i === active) return;
				e.preventDefault();
				activate(i);
			});
			p.addEventListener('keydown', (e) => {
				if ((e.key === 'Enter' || e.key === ' ') && i !== active) {
					e.preventDefault();
					activate(i);
				}
			});
		});

		layout(false);

		let resizeTimer: ReturnType<typeof setTimeout>;
		window.addEventListener('resize', () => {
			clearTimeout(resizeTimer);
			resizeTimer = setTimeout(() => layout(false), 100);
		});

		requestAnimationFrame(() => pagers[active]?.playFirst());
	}

	document.querySelectorAll<HTMLElement>('[data-shelf]').forEach(initShelf);
</script>
