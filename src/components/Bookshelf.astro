---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import VideoChapter from './shelf/VideoChapter.astro';
import PersonChapter from './shelf/PersonChapter.astro';
import ResearchChapter from './shelf/ResearchChapter.astro';
import AudioChapter from './shelf/AudioChapter.astro';

export type Chapter =
	| { type: 'film'; title: string; description?: string; youtubeId?: string; cover: ImageMetadata }
	| { type: 'person'; name: string; images: ImageMetadata[]; href: string }
	| {
			type: 'research';
			title: string;
			authors: string;
			venue: string;
			date: string;
			abstract: string;
			pdf: string;
			doi?: string;
	  }
	| { type: 'audio'; title: string; subtitle?: string; description?: string; src: string }
	| { type: 'video-track'; title: string; description?: string; youtubeId?: string; cover: ImageMetadata };

interface Panel {
	key: string;
	title: string;
	titleEn: string;
	meta: string;
	color: string;
	image?: ImageMetadata;
	chapters: Chapter[];
}

interface Props {
	panels: Panel[];
}

const { panels } = Astro.props;
const total = String(panels.length).padStart(2, '0');
---

<div class="shelf-wrap">
	<div class="shelf" data-shelf>
		{
			panels.map((p, i) => (
				<div
					class="shelf__panel"
					data-panel
					tabindex="0"
					role="button"
					aria-expanded={i === 0 ? 'true' : 'false'}
					aria-label={`${p.title} 열기`}
					style={`--panel-color:${p.color}`}
				>
					<div class="shelf__cover">
						{p.image ? (
							<Image
								src={p.image}
								alt={p.title}
								class="shelf__cover-img"
								widths={[480, 900, 1400]}
								sizes="(max-width: 900px) 100vw, 60vw"
								loading={i === 0 ? 'eager' : 'lazy'}
							/>
						) : (
							<div class="shelf__cover-solid" aria-hidden="true" />
						)}
						<div class="shelf__scrim" aria-hidden="true" />
					</div>

					<span class="shelf__spine-label">
						{p.key} — {p.titleEn}
					</span>

					<div class="shelf__chapters">
						{p.chapters.map((ch, ci) => {
							const index = ci + 1;
							const chTotal = p.chapters.length;
							if (ch.type === 'film' || ch.type === 'video-track') {
								return (
									<VideoChapter
										title={ch.title}
										description={ch.description}
										youtubeId={ch.youtubeId}
										cover={ch.cover}
										index={index}
										total={chTotal}
									/>
								);
							}
							if (ch.type === 'person') {
								return (
									<PersonChapter name={ch.name} images={ch.images} href={ch.href} index={index} total={chTotal} />
								);
							}
							if (ch.type === 'research') {
								return (
									<ResearchChapter
										title={ch.title}
										authors={ch.authors}
										venue={ch.venue}
										date={ch.date}
										abstract={ch.abstract}
										pdf={ch.pdf}
										doi={ch.doi}
										index={index}
										total={chTotal}
									/>
								);
							}
							return (
								<AudioChapter
									title={ch.title}
									subtitle={ch.subtitle}
									description={ch.description}
									src={ch.src}
									index={index}
									total={chTotal}
								/>
							);
						})}
					</div>

					{p.chapters.length > 1 && (
						<div class="shelf__dots" data-shelf-dots aria-hidden="true">
							{p.chapters.map((_, ci) => (
								<button
									class="shelf__dot"
									type="button"
									data-dot-index={ci}
									aria-current={ci === 0 ? 'true' : 'false'}
									aria-label={`챕터 ${ci + 1}`}
								/>
							))}
						</div>
					)}
				</div>
			))
		}
	</div>

	<div class="shelf__controls">
		<button class="shelf__nav" type="button" data-shelf-prev aria-label="이전">
			←
		</button>
		<span class="shelf__count"><span data-shelf-current>01</span> / {total}</span>
		<button class="shelf__nav" type="button" data-shelf-next aria-label="다음">
			→
		</button>
	</div>
</div>

<style>
	.shelf-wrap {
		display: flex;
		flex-direction: column;
		height: calc(100vh - var(--header-h) - 1px);
	}

	.shelf {
		display: flex;
		width: 100%;
		flex: 1 1 auto;
		min-height: 0;
		background: #000;
		gap: 2px;
	}

	.shelf__panel {
		position: relative;
		flex: 0 0 84px;
		overflow: hidden;
		cursor: pointer;
		background: var(--panel-color);
		border: 0;
		padding: 0;
		text-align: left;
		transition: flex-basis 0.6s cubic-bezier(0.65, 0, 0.35, 1);
	}

	.shelf__panel[aria-expanded='true'] {
		flex: 1 1 0%;
		cursor: default;
	}

	.shelf__cover {
		position: absolute;
		inset: 0;
	}

	.shelf__cover :global(.shelf__cover-img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.shelf__cover-solid {
		position: absolute;
		inset: 0;
		background: var(--panel-color);
	}

	.shelf__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(0deg, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.15) 42%, rgba(0, 0, 0, 0.3) 100%);
	}

	.shelf__spine-label {
		position: absolute;
		top: 2rem;
		left: 0;
		right: 0;
		display: flex;
		justify-content: center;
		writing-mode: vertical-rl;
		text-orientation: mixed;
		font-weight: 800;
		font-size: 1rem;
		letter-spacing: 0.12em;
		color: #fff;
		white-space: nowrap;
		transition: opacity 0.25s ease;
	}

	.shelf__panel[aria-expanded='true'] .shelf__spine-label {
		opacity: 0;
		pointer-events: none;
	}

	.shelf__chapters {
		position: absolute;
		inset: 0;
		overflow-y: hidden;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.shelf__panel[aria-expanded='true'] .shelf__chapters {
		opacity: 1;
		transition-delay: 0.25s;
	}

	.shelf__panel:not([aria-expanded='true']) .shelf__chapters {
		pointer-events: none;
	}

	.shelf__dots {
		position: absolute;
		top: 50%;
		right: clamp(1rem, 2vw, 2.25rem);
		transform: translateY(-50%);
		z-index: 5;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.shelf__panel[aria-expanded='true'] .shelf__dots {
		opacity: 1;
		transition-delay: 0.25s;
	}

	.shelf__panel:not([aria-expanded='true']) .shelf__dots {
		pointer-events: none;
	}

	.shelf__dot {
		width: 3px;
		height: 14px;
		padding: 0;
		border: 0;
		background: rgba(255, 255, 255, 0.4);
		cursor: pointer;
		transition:
			height 0.25s ease,
			background 0.25s ease;
	}

	.shelf__dot:hover {
		background: rgba(255, 255, 255, 0.7);
	}

	.shelf__dot[aria-current='true'] {
		height: 26px;
		background: #fff;
	}

	.shelf__controls {
		flex: 0 0 auto;
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 0.75rem var(--gutter);
		font-size: 0.85rem;
		color: var(--color-text-dim);
	}

	.shelf__nav {
		background: none;
		border: 1px solid var(--color-border);
		padding: 0.4rem 0.9rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-family: inherit;
	}

	.shelf__nav:hover {
		border-color: var(--color-border-strong);
	}

	.shelf__count {
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.04em;
	}

	@media (max-width: 720px) {
		.shelf__panel {
			flex-basis: 52px;
		}
	}
</style>

<script>
	function playChapterVideo(el: HTMLElement) {
		if (el.dataset.playing === 'true') return;
		const youtubeId = el.dataset.youtube;
		if (!youtubeId) return;
		const media = el.querySelector('.chapter__media');
		if (!media) return;
		const iframe = document.createElement('iframe');
		iframe.className = 'chapter__iframe';
		iframe.src = `https://www.youtube-nocookie.com/embed/${youtubeId}?autoplay=1&mute=1&controls=1&loop=1&playlist=${youtubeId}&rel=0`;
		iframe.title = el.dataset.title ?? 'video';
		iframe.allow = 'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture';
		media.appendChild(iframe);
		el.dataset.playing = 'true';
	}

	function stopChapterVideo(el: HTMLElement) {
		if (el.dataset.playing !== 'true') return;
		el.querySelector('.chapter__iframe')?.remove();
		el.dataset.playing = 'false';
	}

	// drives paging within one panel's chapter stack: wheel/touch nudge -> snap to next/prev chapter
	function initChapterPaging(panel: HTMLElement) {
		const chaptersEl = panel.querySelector<HTMLElement>('.shelf__chapters');
		if (!chaptersEl) return null;
		const chapters = Array.from(chaptersEl.children) as HTMLElement[];
		const dots = Array.from(panel.querySelectorAll<HTMLButtonElement>('.shelf__dot'));
		let current = 0;
		let cooling = false;

		function updateDots() {
			dots.forEach((d, i) => d.setAttribute('aria-current', String(i === current)));
		}

		function playCurrentIfVideo() {
			const el = chapters[current];
			if (el?.hasAttribute('data-video-chapter')) playChapterVideo(el);
		}

		function goTo(index: number) {
			index = Math.max(0, Math.min(chapters.length - 1, index));
			if (index === current) return;
			const leaving = chapters[current];
			if (leaving?.hasAttribute('data-video-chapter')) stopChapterVideo(leaving);
			current = index;
			chaptersEl!.scrollTo({ top: chapters[current].offsetTop, behavior: 'smooth' });
			updateDots();
			playCurrentIfVideo();
		}

		chaptersEl.addEventListener(
			'wheel',
			(e) => {
				if (panel.getAttribute('aria-expanded') !== 'true') return;
				if (Math.abs(e.deltaY) < 4) return;
				e.preventDefault();
				if (cooling) return;
				cooling = true;
				goTo(current + (e.deltaY > 0 ? 1 : -1));
				setTimeout(() => (cooling = false), 650);
			},
			{ passive: false },
		);

		let touchStartY: number | null = null;
		chaptersEl.addEventListener(
			'touchstart',
			(e) => {
				touchStartY = e.touches[0]?.clientY ?? null;
			},
			{ passive: true },
		);
		chaptersEl.addEventListener(
			'touchend',
			(e) => {
				if (touchStartY === null || cooling) return;
				const dy = touchStartY - (e.changedTouches[0]?.clientY ?? touchStartY);
				touchStartY = null;
				if (Math.abs(dy) < 28) return;
				cooling = true;
				goTo(current + (dy > 0 ? 1 : -1));
				setTimeout(() => (cooling = false), 650);
			},
			{ passive: true },
		);

		dots.forEach((dot, i) => {
			dot.addEventListener('click', (e) => {
				e.stopPropagation();
				goTo(i);
			});
		});

		return {
			reset() {
				const playing = chapters[current];
				if (playing?.hasAttribute('data-video-chapter')) stopChapterVideo(playing);
				current = 0;
				chaptersEl!.scrollTop = 0;
				updateDots();
			},
			playFirst: playCurrentIfVideo,
		};
	}

	function initShelf(shelf: HTMLElement) {
		const panels = Array.from(shelf.querySelectorAll<HTMLElement>('[data-panel]'));
		const wrapper = shelf.closest<HTMLElement>('.shelf-wrap');
		const currentLabel = wrapper?.querySelector('[data-shelf-current]');
		const prevBtn = wrapper?.querySelector('[data-shelf-prev]');
		const nextBtn = wrapper?.querySelector('[data-shelf-next]');
		let active = panels.findIndex((p) => p.getAttribute('aria-expanded') === 'true');
		if (active < 0) active = 0;

		const pagers = panels.map((panel) => initChapterPaging(panel));

		function render() {
			panels.forEach((p, i) => p.setAttribute('aria-expanded', String(i === active)));
			if (currentLabel) currentLabel.textContent = String(active + 1).padStart(2, '0');
		}

		function activate(i: number) {
			const prevIndex = active;
			active = (i + panels.length) % panels.length;
			render();
			if (prevIndex !== active) pagers[prevIndex]?.reset();
			requestAnimationFrame(() => pagers[active]?.playFirst());
		}

		panels.forEach((p, i) => {
			p.addEventListener('click', (e) => {
				if (i === active) return;
				e.preventDefault();
				activate(i);
			});
			p.addEventListener('keydown', (e) => {
				if ((e.key === 'Enter' || e.key === ' ') && i !== active) {
					e.preventDefault();
					activate(i);
				}
			});
		});

		prevBtn?.addEventListener('click', () => activate(active - 1));
		nextBtn?.addEventListener('click', () => activate(active + 1));

		requestAnimationFrame(() => pagers[active]?.playFirst());
	}

	document.querySelectorAll<HTMLElement>('[data-shelf]').forEach(initShelf);
</script>
