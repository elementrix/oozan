---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import GlassButton from './GlassButton.astro';

interface Props {
	youtubeId?: string;
	cover: ImageMetadata;
	title: string;
	aspect?: string;
	class?: string;
}

const { youtubeId, cover, title, aspect = '16 / 9', class: className = '' } = Astro.props;
const isPlaceholder = !youtubeId || youtubeId === 'REPLACE_ME';
---

<div
	class:list={['yt-facade', className]}
	data-youtube={isPlaceholder ? '' : youtubeId}
	data-title={title}
	style={`aspect-ratio: ${aspect};`}
>
	<Image
		src={cover}
		alt={title}
		class="yt-facade__poster"
		widths={[480, 768, 1200, 1600]}
		sizes="(max-width: 768px) 100vw, 60vw"
	/>
	<div class="yt-facade__scrim" aria-hidden="true"></div>
	{
		isPlaceholder ? (
			<span class="yt-facade__badge">영상 업로드 예정</span>
		) : (
			<GlassButton variant="play" class="yt-facade__play" aria-label={`${title} 재생`} />
		)
	}
</div>

<style>
	.yt-facade {
		position: relative;
		width: 100%;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-elevated);
	}

	.yt-facade__poster {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.yt-facade__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(0, 0, 0, 0) 55%, rgba(0, 0, 0, 0.55) 100%);
	}

	.yt-facade__play {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
	}

	.yt-facade__badge {
		position: absolute;
		bottom: 1.25rem;
		left: 1.25rem;
		padding: 0.6rem 1.1rem;
		border-radius: 999px;
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		border: 1px solid var(--color-glass-border);
		background: var(--color-glass-bg);
		backdrop-filter: blur(18px) saturate(160%);
		-webkit-backdrop-filter: blur(18px) saturate(160%);
		color: var(--color-text);
	}

	.yt-facade__iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>

<script>
	document.addEventListener('click', (event) => {
		const target = event.target as HTMLElement;
		const trigger = target.closest<HTMLElement>('.yt-facade__play');
		if (!trigger) return;

		const facade = trigger.closest<HTMLElement>('.yt-facade');
		const youtubeId = facade?.dataset.youtube;
		if (!facade || !youtubeId) return;

		const iframe = document.createElement('iframe');
		iframe.className = 'yt-facade__iframe';
		iframe.src = `https://www.youtube-nocookie.com/embed/${youtubeId}?autoplay=1&rel=0`;
		iframe.title = facade.dataset.title ?? 'YouTube video';
		iframe.allow =
			'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
		iframe.allowFullscreen = true;

		facade.replaceChildren(iframe);
	});
</script>
