---
import { withBase } from '../../lib/url';

interface Props {
	name: string;
	role: string;
	email: string;
	phone: string;
	instagram: string;
	index: number;
	total: number;
}

const { name, role, email, phone, instagram, index, total } = Astro.props;
---

<section class="chapter">
	<p class="chapter__index">
		{String(index).padStart(2, '0')} / {String(total).padStart(2, '0')}
	</p>
	<div class="chapter__stage">
		<img src={withBase('/brand/oozan-logo.png')} alt="Oozan" class="chapter__logo" />
		<h4 class="chapter__title">{name}</h4>
		<p class="chapter__role">{role}</p>
		<div class="chapter__contact">
			<a class="chapter__contact-item" href={`mailto:${email}`}>
				<span class="chapter__contact-label">Email</span>
				<span class="chapter__contact-value">{email}</span>
			</a>
			<a class="chapter__contact-item" href={`tel:${phone.replace(/-/g, '')}`}>
				<span class="chapter__contact-label">Phone</span>
				<span class="chapter__contact-value">{phone}</span>
			</a>
			<a class="chapter__contact-item" href={`https://www.instagram.com/${instagram}`} target="_blank" rel="noopener noreferrer">
				<span class="chapter__contact-label">Instagram</span>
				<span class="chapter__contact-value">@{instagram}</span>
			</a>
		</div>
	</div>
</section>

<style>
	.chapter {
		position: relative;
		height: 100%;
		width: 100%;
		overflow: hidden;
		background: var(--panel-color);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.chapter__index {
		position: absolute;
		top: clamp(1.5rem, 3vw, 2.25rem);
		left: clamp(1.5rem, 3vw, 2.25rem);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		color: rgba(255, 255, 255, 0.65);
	}

	.chapter__stage {
		width: 100%;
		max-width: 640px;
		padding: clamp(1.5rem, 4vw, 3rem);
		text-align: center;
	}

	.chapter__logo {
		height: clamp(2.4rem, 5vw, 3.75rem);
		width: auto;
		display: block;
		margin: 0 auto;
		filter: invert(1);
	}

	.chapter__title {
		margin-top: clamp(1.5rem, 4vw, 2.5rem);
		font-size: clamp(2.75rem, 7vw, 5rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		line-height: 1.05;
		color: #fff;
	}

	.chapter__role {
		margin-top: 0.9rem;
		font-size: clamp(0.95rem, 1.6vw, 1.15rem);
		color: rgba(255, 255, 255, 0.8);
	}

	.chapter__contact {
		margin-top: clamp(2rem, 5vw, 3rem);
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		border-top: 1px solid rgba(255, 255, 255, 0.2);
		padding-top: 1.25rem;
		text-align: left;
	}

	.chapter__contact-item {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		color: #fff;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.14);
	}

	.chapter__contact-item:last-child {
		border-bottom: 0;
		padding-bottom: 0;
	}

	.chapter__contact-label {
		flex-shrink: 0;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(255, 255, 255, 0.55);
	}

	.chapter__contact-value {
		font-size: clamp(0.95rem, 1.4vw, 1.1rem);
		font-weight: 600;
		text-align: right;
	}

	.chapter__contact-item:hover .chapter__contact-value {
		text-decoration: underline;
	}
</style>
