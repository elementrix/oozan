---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	name: string;
	images: ImageMetadata[];
	index: number;
	total: number;
}

const { name, images, index, total } = Astro.props;
// pad with clones of the last/first photo so the peek carousel can wrap seamlessly
const padded = images.length > 1 ? [images[images.length - 1], ...images, images[0]] : images;
---

<section class="chapter">
	<div class="chapter__gallery" data-h-gallery data-total={images.length}>
		{
			padded.map((img, i) => (
				<div class="chapter__slide" data-slide data-slide-i={i}>
					<Image
						src={img}
						alt={name}
						class="chapter__photo"
						widths={[480, 900, 1400]}
						sizes="(max-width: 900px) 70vw, 32vw"
						loading="lazy"
					/>
				</div>
			))
		}
	</div>

	{
		images.length > 1 && (
			<>
				<button class="chapter__hnav chapter__hnav--prev" type="button" data-h-prev aria-label="이전 사진">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M15 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
				<button class="chapter__hnav chapter__hnav--next" type="button" data-h-next aria-label="다음 사진">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
			</>
		)
	}

	<div class="chapter__scrim" aria-hidden="true"></div>
	<div class="chapter__body">
		{
			images.length > 1 && (
				<div class="chapter__hdots" data-h-dots aria-hidden="true">
					{images.map((_, i) => (
						<button
							class="chapter__hdot"
							type="button"
							data-h-dot-index={i}
							aria-current={i === 0 ? 'true' : 'false'}
							aria-label={`사진 ${i + 1}`}
						/>
					))}
				</div>
			)
		}
		<p class="chapter__index">
			{String(index).padStart(2, '0')} / {String(total).padStart(2, '0')}
		</p>
		<h4 class="chapter__title">{name}</h4>
	</div>
</section>

<style>
	.chapter {
		position: relative;
		height: 100%;
		width: 100%;
		overflow: hidden;
		background: var(--panel-color);
	}

	.chapter__gallery {
		position: absolute;
		inset: 0;
	}

	.chapter__slide {
		position: absolute;
		top: 0;
		height: 100%;
		aspect-ratio: 3 / 4;
		border-right: 1px solid rgba(255, 255, 255, 0.55);
		transition: left 0.45s cubic-bezier(0.65, 0, 0.35, 1);
	}

	.chapter__slide :global(.chapter__photo) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: brightness(0.5);
	}

	.chapter__slide.is-active :global(.chapter__photo) {
		object-fit: contain;
		filter: none;
	}

	.chapter__hnav {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		z-index: 6;
		border: 0;
		background: rgba(0, 0, 0, 0.45);
		color: #fff;
		padding: 0.75rem 0.6rem;
		cursor: pointer;
		opacity: 0.85;
	}

	.chapter__hnav:hover {
		opacity: 1;
	}

	.chapter__hnav--prev {
		left: 0.75rem;
	}

	.chapter__hnav--next {
		right: 3.25rem;
	}

	.chapter__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(0deg, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0) 32%);
		pointer-events: none;
	}

	.chapter__body {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		max-width: 640px;
		padding: clamp(1.5rem, 3vw, 3rem);
		pointer-events: none;
	}

	.chapter__body > * {
		pointer-events: auto;
	}

	.chapter__hdots {
		display: flex;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}

	.chapter__hdot {
		width: 14px;
		height: 3px;
		padding: 0;
		border: 0;
		background: rgba(255, 255, 255, 0.4);
		cursor: pointer;
		transition:
			width 0.25s ease,
			background 0.25s ease;
	}

	.chapter__hdot:hover {
		background: rgba(255, 255, 255, 0.7);
	}

	.chapter__hdot[aria-current='true'] {
		width: 26px;
		background: #fff;
	}

	.chapter__index {
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		color: rgba(255, 255, 255, 0.75);
	}

	.chapter__title {
		margin-top: 0.5rem;
		font-size: clamp(1.6rem, 3.5vw, 2.5rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		color: #fff;
	}
</style>

<script>
	const GAP_PX = 0;
	const TRANSITION_MS = 460;

	function initHGallery(gallery: HTMLElement) {
		const total = Number(gallery.dataset.total ?? 0);
		if (total < 2) return;
		const slides = Array.from(gallery.querySelectorAll<HTMLElement>('[data-slide]'));
		const chapter = gallery.closest<HTMLElement>('.chapter');
		const dots = Array.from(chapter?.querySelectorAll<HTMLButtonElement>('.chapter__hdot') ?? []);
		const prevBtn = chapter?.querySelector<HTMLElement>('[data-h-prev]');
		const nextBtn = chapter?.querySelector<HTMLElement>('[data-h-next]');

		let virtual = 1; // index into the padded [last, ...real, first] array; 1 == real index 0
		let cooling = false;

		function position(animate: boolean) {
			const cardWidth = slides[0].getBoundingClientRect().width;
			const step = cardWidth + GAP_PX;
			const centerOffset = (gallery.clientWidth - cardWidth) / 2;
			slides.forEach((el, i) => {
				if (!animate) el.style.transition = 'none';
				el.style.left = `${centerOffset + (i - virtual) * step}px`;
				el.classList.toggle('is-active', i === virtual);
			});
			if (!animate) {
				void gallery.offsetHeight; // force reflow before re-enabling transitions
				slides.forEach((el) => {
					el.style.transition = '';
				});
			}
		}

		function updateDots() {
			const real = (((virtual - 1) % total) + total) % total;
			dots.forEach((d, i) => d.setAttribute('aria-current', String(i === real)));
		}

		function step(dir: number) {
			virtual += dir;
			position(true);
			updateDots();
			setTimeout(() => {
				if (virtual === total + 1) {
					virtual = 1;
					position(false);
				} else if (virtual === 0) {
					virtual = total;
					position(false);
				}
			}, TRANSITION_MS);
		}

		function jumpTo(real: number) {
			virtual = real + 1;
			position(true);
			updateDots();
		}

		position(false);
		updateDots();

		let resizeTimer: ReturnType<typeof setTimeout>;
		window.addEventListener('resize', () => {
			clearTimeout(resizeTimer);
			resizeTimer = setTimeout(() => position(false), 100);
		});

		// the panel starts collapsed (84px wide), so the initial layout above is measured
		// against the wrong width — recompute once it finishes animating open
		const panel = gallery.closest<HTMLElement>('.shelf__panel');
		panel?.addEventListener('transitionend', (e) => {
			if (e.propertyName === 'flex-basis') position(false);
		});

		function guardedStep(dir: number) {
			if (cooling) return;
			cooling = true;
			step(dir);
			setTimeout(() => (cooling = false), TRANSITION_MS + 40);
		}

		prevBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			guardedStep(-1);
		});
		nextBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			guardedStep(1);
		});
		dots.forEach((dot, i) => {
			dot.addEventListener('click', (e) => {
				e.stopPropagation();
				jumpTo(i);
			});
		});

		gallery.addEventListener(
			'wheel',
			(e) => {
				if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return; // vertical intent: let it bubble to chapter pager
				e.preventDefault();
				e.stopPropagation();
				if (Math.abs(e.deltaX) < 4) return;
				guardedStep(e.deltaX > 0 ? 1 : -1);
			},
			{ passive: false },
		);

		let startX = 0;
		let startY = 0;
		gallery.addEventListener(
			'touchstart',
			(e) => {
				startX = e.touches[0]?.clientX ?? 0;
				startY = e.touches[0]?.clientY ?? 0;
			},
			{ passive: true },
		);
		gallery.addEventListener(
			'touchend',
			(e) => {
				const endX = e.changedTouches[0]?.clientX ?? startX;
				const endY = e.changedTouches[0]?.clientY ?? startY;
				const dx = startX - endX;
				const dy = startY - endY;
				if (Math.abs(dx) <= Math.abs(dy) || Math.abs(dx) < 28) return; // vertical-dominant: let chapter pager handle it
				e.stopPropagation();
				guardedStep(dx > 0 ? 1 : -1);
			},
			{ passive: true },
		);
	}

	document.querySelectorAll<HTMLElement>('[data-h-gallery]').forEach(initHGallery);
</script>
