---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	subtitle?: string;
	description?: string;
	src: string;
	cover?: ImageMetadata;
	index: number;
	total: number;
}

const { title, subtitle, description, src, cover, index, total } = Astro.props;
---

<section class="chapter" data-chapter data-audio-chapter data-playing="false" data-muted="false">
	<div class="chapter__ambient" aria-hidden="true">
		{cover && <Image src={cover} alt="" class="chapter__ambient-img" widths={[480, 900]} sizes="60vw" loading="lazy" />}
	</div>
	<div class="chapter__scrim" aria-hidden="true"></div>

	<p class="chapter__index">{String(index).padStart(2, '0')} / {String(total).padStart(2, '0')}</p>

	<div class="chapter__stage">
		<div class="chapter__art">
			{
				cover ? (
					<Image src={cover} alt={title} class="chapter__art-img" widths={[480, 900]} sizes="(max-width: 720px) 70vw, 32vw" loading="lazy" />
				) : (
					<div class="chapter__art-placeholder" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 18V5l12-2v13" />
							<circle cx="6" cy="18" r="3" />
							<circle cx="18" cy="16" r="3" />
						</svg>
					</div>
				)
			}
		</div>
		<div class="chapter__info">
			<h4 class="chapter__title">{title}</h4>
			{subtitle && <p class="chapter__subtitle">{subtitle}</p>}
			{description && <p class="chapter__desc">{description}</p>}
		</div>
	</div>

	<div class="chapter__player">
		<audio data-audio-el preload="metadata" src={src}></audio>
		<div class="chapter__progress">
			<span class="chapter__time" data-time-current>0:00</span>
			<div class="chapter__progress-track" data-progress-track>
				<div class="chapter__progress-fill" data-progress-fill></div>
			</div>
			<span class="chapter__time" data-time-duration>0:00</span>
		</div>
		<div class="chapter__transport">
			<button class="chapter__transport-btn" type="button" data-audio-mute aria-label="음소거">
				<svg class="chapter__mute-icon chapter__mute-icon--off" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
					<path d="M4 9v6h4l5 5V4L8 9H4Z" />
					<path d="M16.5 12 19 9.5m0 5L16.5 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none" />
				</svg>
				<svg class="chapter__mute-icon chapter__mute-icon--on" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
					<path d="M4 9v6h4l5 5V4L8 9H4Z" />
					<path d="M16 8.5a5 5 0 0 1 0 7M18.5 6a8.5 8.5 0 0 1 0 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none" />
				</svg>
			</button>
			<div class="chapter__transport-main">
				<button class="chapter__transport-btn" type="button" data-audio-prev aria-label="이전 트랙">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
						<path d="M6 5h2v14H6zM19 5 9 12l10 7z" />
					</svg>
				</button>
				<button class="chapter__play-btn" type="button" data-audio-toggle aria-label="재생">
					<svg class="chapter__play-icon chapter__play-icon--play" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
						<path d="M8 5v14l12-7z" />
					</svg>
					<svg class="chapter__play-icon chapter__play-icon--pause" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
						<path d="M7 5h4v14H7zM13 5h4v14h-4z" />
					</svg>
				</button>
				<button class="chapter__transport-btn" type="button" data-audio-next aria-label="다음 트랙">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
						<path d="M16 5h2v14h-2zM5 5l10 7-10 7z" />
					</svg>
				</button>
			</div>
			<div class="chapter__transport-btn chapter__transport-spacer" aria-hidden="true"></div>
		</div>
	</div>
</section>

<style>
	.chapter {
		position: relative;
		height: 100%;
		width: 100%;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		background: radial-gradient(120% 90% at 50% 0%, color-mix(in srgb, var(--panel-color) 45%, #050505) 0%, #050505 70%);
		color: #fff;
	}

	.chapter__ambient {
		position: absolute;
		inset: -12%;
		z-index: 0;
	}

	.chapter__ambient :global(.chapter__ambient-img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: blur(70px) saturate(1.7) brightness(0.7);
		transform: scale(1.15);
	}

	.chapter__scrim {
		position: absolute;
		inset: 0;
		z-index: 1;
		background: rgba(0, 0, 0, 0.3);
	}

	.chapter__index {
		position: relative;
		z-index: 2;
		padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1.5rem, 3vw, 2.25rem) 0;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		color: rgba(255, 255, 255, 0.65);
	}

	.chapter__stage {
		position: relative;
		z-index: 2;
		flex: 1 1 auto;
		min-height: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		padding: 1rem clamp(1.5rem, 4vw, 3rem);
		text-align: center;
	}

	.chapter__art {
		width: min(46%, 320px);
		aspect-ratio: 1;
		border-radius: 14px;
		overflow: hidden;
		box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.7);
		transition: box-shadow 0.3s ease;
	}

	.chapter[data-playing='true'] .chapter__art {
		box-shadow: 0 40px 80px -18px rgba(0, 0, 0, 0.8);
	}

	.chapter__art :global(.chapter__art-img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.chapter__art-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: color-mix(in srgb, var(--panel-color) 35%, #000);
		color: rgba(255, 255, 255, 0.55);
	}

	.chapter__info {
		max-width: 420px;
	}

	.chapter__title {
		font-size: clamp(1.15rem, 2vw, 1.5rem);
		font-weight: 800;
		letter-spacing: -0.01em;
		line-height: 1.25;
	}

	.chapter__subtitle {
		margin-top: 0.4rem;
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.65);
	}

	.chapter__desc {
		margin-top: 0.75rem;
		font-size: 0.85rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.7);
	}

	.chapter__player {
		position: relative;
		z-index: 2;
		flex: 0 0 auto;
		padding: 0 clamp(1.5rem, 4vw, 3rem) clamp(1.5rem, 3vw, 2.25rem);
	}

	.chapter__progress {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.chapter__time {
		font-size: 0.7rem;
		font-variant-numeric: tabular-nums;
		color: rgba(255, 255, 255, 0.55);
		width: 2.4rem;
		flex-shrink: 0;
	}

	.chapter__time:last-child {
		text-align: right;
	}

	.chapter__progress-track {
		flex: 1 1 auto;
		height: 3px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.25);
		cursor: pointer;
	}

	.chapter__progress-fill {
		height: 100%;
		width: 0%;
		border-radius: 999px;
		background: #fff;
	}

	.chapter__transport {
		margin-top: 1.1rem;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
	}

	.chapter__transport-main {
		grid-column: 2;
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}

	.chapter__transport-spacer {
		visibility: hidden;
	}

	.chapter__transport-btn {
		flex-shrink: 0;
		width: 2.25rem;
		height: 2.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 0;
		border-radius: 999px;
		background: none;
		color: #fff;
		opacity: 0.85;
		cursor: pointer;
	}

	.chapter__transport-btn:hover {
		opacity: 1;
	}

	.chapter__play-btn {
		flex-shrink: 0;
		width: 3.25rem;
		height: 3.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 0;
		border-radius: 999px;
		background: #fff;
		color: #0a0a0a;
		cursor: pointer;
	}

	.chapter__play-icon--pause {
		display: none;
	}

	.chapter[data-playing='true'] .chapter__play-icon--play {
		display: none;
	}

	.chapter[data-playing='true'] .chapter__play-icon--pause {
		display: block;
	}

	.chapter__mute-icon--on {
		display: none;
	}

	.chapter[data-muted='true'] .chapter__mute-icon--off {
		display: none;
	}

	.chapter[data-muted='true'] .chapter__mute-icon--on {
		display: block;
	}

	@media (max-width: 640px) {
		.chapter__art {
			width: min(60%, 240px);
		}

		.chapter__stage {
			gap: 1.1rem;
		}
	}
</style>

<script>
	function formatTime(seconds: number): string {
		if (!Number.isFinite(seconds)) return '0:00';
		const total = Math.max(0, Math.floor(seconds));
		const m = Math.floor(total / 60);
		const s = total % 60;
		return `${m}:${String(s).padStart(2, '0')}`;
	}

	function initAudioChapter(chapter: HTMLElement) {
		const audio = chapter.querySelector<HTMLAudioElement>('[data-audio-el]');
		if (!audio) return;
		const toggleBtn = chapter.querySelector<HTMLButtonElement>('[data-audio-toggle]');
		const prevBtn = chapter.querySelector<HTMLButtonElement>('[data-audio-prev]');
		const nextBtn = chapter.querySelector<HTMLButtonElement>('[data-audio-next]');
		const muteBtn = chapter.querySelector<HTMLButtonElement>('[data-audio-mute]');
		const track = chapter.querySelector<HTMLElement>('[data-progress-track]');
		const fill = chapter.querySelector<HTMLElement>('[data-progress-fill]');
		const currentLabel = chapter.querySelector<HTMLElement>('[data-time-current]');
		const durationLabel = chapter.querySelector<HTMLElement>('[data-time-duration]');

		audio.addEventListener('loadedmetadata', () => {
			if (durationLabel) durationLabel.textContent = formatTime(audio.duration);
		});
		audio.addEventListener('timeupdate', () => {
			if (currentLabel) currentLabel.textContent = formatTime(audio.currentTime);
			if (fill && audio.duration) fill.style.width = `${(audio.currentTime / audio.duration) * 100}%`;
		});
		audio.addEventListener('play', () => (chapter.dataset.playing = 'true'));
		audio.addEventListener('pause', () => (chapter.dataset.playing = 'false'));
		audio.addEventListener('ended', () => {
			chapter.dataset.playing = 'false';
			if (fill) fill.style.width = '0%';
		});

		toggleBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			if (audio.paused) audio.play();
			else audio.pause();
		});

		prevBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			chapter.dispatchEvent(new CustomEvent('chapter-step', { bubbles: true, detail: { dir: -1 } }));
		});
		nextBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			chapter.dispatchEvent(new CustomEvent('chapter-step', { bubbles: true, detail: { dir: 1 } }));
		});

		muteBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			audio.muted = !audio.muted;
			chapter.dataset.muted = String(audio.muted);
		});

		track?.addEventListener('click', (e) => {
			e.stopPropagation();
			if (!audio.duration) return;
			const rect = track.getBoundingClientRect();
			const frac = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
			audio.currentTime = frac * audio.duration;
		});
	}

	document.querySelectorAll<HTMLElement>('[data-audio-chapter]').forEach(initAudioChapter);
</script>
