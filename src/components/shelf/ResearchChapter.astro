---
interface Props {
	title: string;
	authors: string;
	venue: string;
	date: string;
	abstract: string;
	pdf: string;
	doi?: string;
	index: number;
	total: number;
}

const { title, authors, venue, date, abstract, pdf, doi, index, total } = Astro.props;
---

<section class="chapter">
	<div class="chapter__inner">
		<p class="chapter__index">
			{String(index).padStart(2, '0')} / {String(total).padStart(2, '0')}
		</p>
		<h4 class="chapter__title">{title}</h4>
		<div class="chapter__meta">
			<span><b>Authors</b>{authors}</span>
			<span><b>Published in</b>{venue}</span>
			<span><b>Date</b>{date}</span>
		</div>
		<p class="chapter__abstract-label">Abstract</p>
		<p class="chapter__abstract">{abstract}</p>
		<div class="chapter__actions">
			<a class="chapter__btn" href={pdf} target="_blank" rel="noopener noreferrer">PDF 보기</a>
			{
				doi && (
					<a class="chapter__btn" href={doi} target="_blank" rel="noopener noreferrer">
						DOI ↗
					</a>
				)
			}
		</div>
	</div>
</section>

<style>
	.chapter {
		position: relative;
		height: 100%;
		width: 100%;
		scroll-snap-align: start;
		scroll-snap-stop: always;
		overflow-y: auto;
		background: var(--panel-color);
	}

	.chapter__inner {
		max-width: 640px;
		padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 3vw, 3rem);
	}

	.chapter__index {
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		color: rgba(255, 255, 255, 0.75);
	}

	.chapter__title {
		margin-top: 0.75rem;
		font-size: clamp(1.5rem, 3vw, 2.1rem);
		font-weight: 800;
		letter-spacing: -0.015em;
		line-height: 1.25;
		color: #fff;
	}

	.chapter__meta {
		margin-top: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.8);
		border-top: 1px solid rgba(255, 255, 255, 0.2);
		border-bottom: 1px solid rgba(255, 255, 255, 0.2);
		padding-block: 0.9rem;
	}

	.chapter__meta span b {
		display: block;
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(255, 255, 255, 0.55);
		margin-bottom: 0.15rem;
	}

	.chapter__abstract-label {
		margin-top: 1.5rem;
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: rgba(255, 255, 255, 0.55);
	}

	.chapter__abstract {
		margin-top: 0.6rem;
		font-size: 0.88rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.88);
	}

	.chapter__actions {
		margin-top: 1.75rem;
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.chapter__btn {
		display: inline-flex;
		padding: 0.7rem 1.3rem;
		border: 1px solid rgba(255, 255, 255, 0.4);
		color: #fff;
		font-weight: 700;
		font-size: 0.85rem;
	}

	.chapter__btn:hover {
		background: rgba(255, 255, 255, 0.14);
		border-color: #fff;
	}
</style>
