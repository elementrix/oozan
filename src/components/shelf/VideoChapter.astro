---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description?: string;
	youtubeId?: string;
	cover: ImageMetadata;
	index: number;
	total: number;
}

const { title, description, youtubeId, cover, index, total } = Astro.props;
const isPlaceholder = !youtubeId || youtubeId === 'REPLACE_ME';
---

<section
	class="chapter"
	data-chapter
	data-video-chapter
	data-youtube={isPlaceholder ? '' : youtubeId}
	data-title={title}
>
	<div class="chapter__media">
		<Image
			src={cover}
			alt={title}
			class="chapter__poster"
			widths={[480, 900, 1400]}
			sizes="(max-width: 900px) 100vw, 60vw"
			loading="lazy"
		/>
		<div class="chapter__scrim" aria-hidden="true"></div>
	</div>
	{isPlaceholder && <span class="chapter__badge">영상 업로드 예정</span>}
	<div class="chapter__body">
		<p class="chapter__index">
			{String(index).padStart(2, '0')} / {String(total).padStart(2, '0')}
		</p>
		<h4 class="chapter__title">{title}</h4>
		{description && <p class="chapter__desc">{description}</p>}
	</div>
</section>

<style>
	.chapter {
		position: relative;
		height: 100%;
		width: 100%;
		scroll-snap-align: start;
		scroll-snap-stop: always;
		overflow: hidden;
	}

	.chapter__media {
		position: absolute;
		inset: 0;
	}

	.chapter__media :global(.chapter__poster),
	.chapter__media :global(.chapter__iframe) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border: 0;
	}

	.chapter__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(0deg, rgba(0, 0, 0, 0.82) 0%, rgba(0, 0, 0, 0.05) 40%, rgba(0, 0, 0, 0.25) 100%);
		pointer-events: none;
	}

	.chapter[data-playing='true'] .chapter__scrim {
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.chapter__badge {
		position: absolute;
		top: 1.5rem;
		left: 1.5rem;
		padding: 0.55rem 1rem;
		font-size: 0.75rem;
		letter-spacing: 0.04em;
		border: 1px solid rgba(255, 255, 255, 0.35);
		background: rgba(20, 20, 22, 0.45);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		color: #fff;
	}

	.chapter__body {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		max-width: 640px;
		padding: clamp(1.5rem, 3vw, 3rem);
		pointer-events: none;
	}

	.chapter[data-playing='true'] .chapter__body {
		opacity: 0;
		transform: translateY(12px);
		transition:
			opacity 0.25s ease,
			transform 0.25s ease;
	}

	.chapter__index {
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		color: rgba(255, 255, 255, 0.75);
	}

	.chapter__title {
		margin-top: 0.5rem;
		font-size: clamp(1.6rem, 3.5vw, 2.5rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		line-height: 1.05;
		color: #fff;
	}

	.chapter__desc {
		margin-top: 0.75rem;
		font-size: 0.9rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.85);
	}
</style>
