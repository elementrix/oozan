---
interface Props {
	title: string;
	subtitle?: string;
	src: string;
	index?: number;
}

const { title, subtitle, src, index } = Astro.props;
---

<article class="audio-card">
	<div class="audio-card__head">
		{index !== undefined && <span class="audio-card__index">{String(index).padStart(2, '0')}</span>}
		<div>
			<h3 class="audio-card__title">{title}</h3>
			{subtitle && <p class="audio-card__subtitle">{subtitle}</p>}
		</div>
	</div>
	<audio class="audio-card__player" controls preload="none" src={src}>
		<a href={src}>오디오 파일 다운로드</a>
	</audio>
</article>

<style>
	.audio-card {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding: clamp(1.25rem, 3vw, 2rem);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: var(--color-bg-card);
	}

	.audio-card__head {
		display: flex;
		align-items: baseline;
		gap: 1rem;
	}

	.audio-card__index {
		font-size: 0.85rem;
		color: var(--color-accent);
		font-weight: 700;
		letter-spacing: 0.04em;
	}

	.audio-card__title {
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.audio-card__subtitle {
		margin-top: 0.2rem;
		font-size: 0.85rem;
		color: var(--color-text-dim);
	}

	.audio-card__player {
		width: 100%;
		height: 40px;
		accent-color: var(--color-accent);
	}
</style>
